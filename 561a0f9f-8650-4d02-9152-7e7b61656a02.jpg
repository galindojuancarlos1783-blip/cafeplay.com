*{
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Roboto", sans-serif;
    

}


    

.main{
    width: 100%;
    height: 100vh;
}

/*inicio seccion 1*/
.section-1{
    width: 100%;
    height: 10em;
    background: linear-gradient(90deg,#9824b0,#ff5500);
    padding-top: 1.5em;
}
.header{
    background-color: #2d2f3e;
    width: 100%;
    height: 3.5em;
    display: flex;
    flex-direction: row;
    overflow: hidden;
    
    
    
}
.img{

width: 25%;
height: 100;
}
.menu{

width: 55%;
height: 100;
display: flex;
flex-direction: row;
justify-content: right;
align-items: center;
}
.img img{
    object-fit: cover;
    height: 100%;
}
.menu a{
    display: flex;
    text-decoration: none;
    color: #fff;
    padding: 2em 1em;
}
.menu a:hover{
   background-color: #ff5500;
    
}
/*finaliza seccion 1*/

/*inicia seccion 2*/
.section-2{
    width: 100%;
    height: calc(100vh -20em);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 1em 0;
    
  }  

.s2-textos{
width: 80%;
height: 25%;

}
.s2-img{
background-color: #2d2f3e;
width: 80%;
height: 75%;
display: flex;
flex-direction: row;
}
.titulo{
font-size: 2em;
text-align: center;
color: #454245;
}
.s2-textos hr{
width: 3em;
height:0.25em ;
 background: linear-gradient(90deg,#9824b0,#ff5500);
 border: none;
 border-radius: 1em;
 margin: 0.25em auto;
}
.s2-textos p{
    font-size: 1.25em;
}


.s2-contenido{
    width: 33.33%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    padding: 0.5em;
}
.contenido-img{
     width: 100%;
    height: 50%;
    overflow: hidden;
   
}

.contenido-img img{
    object-fit: cover;
    width: 100%
    
}

.contenido-texto{
    width: 100%;
    height: 50%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    padding: 0.5em 0;
    
}
.contenido-texto h2{
    font-size: 1.25em;
    color: #ff5500;

}
.contenido-texto p{
    font-size: 1.1em;
    color: #fff;
    margin: 0.5em 0;
    text-align: center;
}
.contenido-texto a{
    text-decoration: none;
    color: #fff;
    background-color: #ff5500;
    width: 35%;
    padding:  0.5em 0;
    border: none;
    border-radius: 0.32em;
    text-align: center;
 }   

/*finaliza seccion 2*/




/*inicia seccion 3*/
.section-3{
    width: 100%;
    height: 10em;
    background: #2d2f3e;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;

}

.section-3 hr{
    background: linear-gradient(90deg,#9824b0,#ff5500);
    width: 100%;
    height: 5%;
    border: none;

}
.s3-contenido{
width: 100%;
height: 65%;
display: flex;
flex-direction: row;
justify-content: center;


}
.s3-logo{
    width: 50%;
    
}

.s3-logo img{
    object-fit: cover;
      height: 100%;
   
}

.s3-texto{
    width: 30%;
    
}

.s3-texto h3{
    font-size: 1.1em;
    color: #fff;
    margin: 0.25em 0;
}
.s3-texto p{
    font-size: 0.9em;
    color: #fff;
}
.s3-texto a{
    text-decoration: none;
    font-size: 0.9em;
    color: #fff;
}
footer{
    width: 100%;
    height: 30%;
    border-top: #535353 solid 0.0725em;
    display: flex;
    flex-direction: row;
    justify-content: left;
    align-items: center;
    color: #fff;
    padding: 0 10%;
}
.autor{
text-decoration: none;
    color: #fff;
    margin: 0.25em;
}
.politicas{
text-decoration: none;
    color: #fff;
    margin: 5em;
} 

/*finaliza seccion 3*/